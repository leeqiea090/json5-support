{
  "name": "json5-support",
  "displayName": "JSON5 Support",
  "description": "Syntax highlighting, diagnostics, and formatting support for JSON5 files in VS Code",
  "version": "0.0.1",
  "publisher": "leeqiea090",
  "engines": {
    "vscode": "^1.115.0"
  },
  "icon": "resources/json-128.png",
  "categories": [
    "Programming Languages",
    "Formatters"
  ],
  "keywords": [
    "json5",
    "json",
    "formatter",
    "diagnostics",
    "syntax"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/leeqiea090/json5-support.git"
  },
  "homepage": "https://github.com/leeqiea090/json5-support#readme",
  "bugs": {
    "url": "https://github.com/leeqiea090/json5-support/issues"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "json5",
        "aliases": [
          "JSON5",
          "json5"
        ],
        "extensions": [
          ".json5"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "json5",
        "scopeName": "source.json5",
        "path": "./syntaxes/json5.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "package:vsix": "node ./scripts/vsce.js package --skip-license",
    "publish:marketplace": "node ./scripts/vsce.js publish --skip-license",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.115.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@croct/json5-parser": "^0.2.2"
  }
}